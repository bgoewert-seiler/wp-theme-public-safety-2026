{
  "$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/wp-env.json",
  "themes": [
    "./src"
  ],
  "plugins": [
    "https://downloads.wordpress.org/plugin/contact-form-7.latest-stable.zip",
    "https://downloads.wordpress.org/plugin/woocommerce.latest-stable.zip",
    "https://downloads.wordpress.org/plugin/splide-carousel.latest-stable.zip",
    "../seiler-forms/.local/plugins/gravityforms",
    "../seiler-events/.local/plugins/the-events-calendar",
    "../seiler-events/.local/plugins/events-calendar-pro",
    "../seiler-events/.local/plugins/event-tickets",
    "../seiler-events/.local/plugins/event-tickets-plus"
  ],
  "config": {
    "WP_ENVIRONMENT_TYPE": "local",
    "WP_DEBUG": true,
    "WP_DEBUG_LOG": true,
    "WP_DEBUG_DISPLAY": true,
    "WP_MEMORY_LIMIT": "512M",
    "WP_MAX_MEMORY_LIMIT": "512M"
  },
  "port": 8890,
  "testsPort": 8891,
  "https": true,
  "httpsPort": 8443,
  "testsHttpsPort": 8444,
  "lifecycleScripts": {
    "afterStart": "wp-env run cli wp theme activate src && wp-env run cli wp rewrite structure '/%postname%/' && wp-env run cli wp rewrite flush"
  }
}
