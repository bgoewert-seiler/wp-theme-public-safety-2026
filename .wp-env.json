{
  "$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/wp-env.json",
  "themes": [
    "."
  ],
  "plugins": [
    "https://downloads.wordpress.org/plugin/contact-form-7.latest-stable.zip",
    "https://downloads.wordpress.org/plugin/woocommerce.latest-stable.zip",
    "../seiler-forms/.local/plugins/gravityforms"
  ],
  "config": {
    "WP_ENVIRONMENT_TYPE": "local",
    "WP_DEBUG": true,
    "WP_DEBUG_LOG": true,
    "WP_DEBUG_DISPLAY": true
  },
  "port": 8890,
  "testsPort": 8891,
  "https": true,
  "httpsPort": 8443,
  "testsHttpsPort": 8444,
  "lifecycleScripts": {
    "afterStart": "wp-env run cli wp theme activate wp-theme-public-safety-2026 && wp-env run cli wp rewrite structure '/%postname%/' && wp-env run cli wp rewrite flush"
  },
  "env": {
    "development": {
      "themes": [
        "."
      ]
    }
  }
}
